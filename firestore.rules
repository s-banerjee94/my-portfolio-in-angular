rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public site content: world-readable, only the authenticated admin writes.
    // Collections are enumerated on purpose — no catch-all, so nothing added
    // later is exposed by accident and /messages is not readable via a
    // wildcard (rules are OR'ed: any matching allow grants access).
    match /profile/{section} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /projects/{project} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /experience/{role} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /certifications/{certification} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /resumes/{resume} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // FCM device tokens for the admin's push notifications — admin-only in
    // both directions; visitors never touch this collection.
    match /fcmTokens/{token} {
      allow read, write: if request.auth != null;
    }

    // Contact-form inbox: anyone may CREATE a well-formed message, but only
    // the authenticated admin can read, mark as read, or delete. Public
    // update/delete stays forbidden so strangers can't tamper with the inbox.
    match /messages/{message} {
      allow create: if isValidMessage();
      allow read, update, delete: if request.auth != null;
    }

    // Visit analytics: the public site logs one small doc per visit/click.
    // Create-only and shape-checked; visits are immutable once written, and
    // only the authenticated admin can read or prune them.
    match /visits/{visit} {
      allow create: if isValidVisit();
      allow read, delete: if request.auth != null;
    }

    function isValidVisit() {
      let data = request.resource.data;
      return data.keys().hasOnly(['event', 'source', 'referrer', 'path', 'device', 'browser', 'language', 'timezone', 'timestamp', 'meta', 'visitorId', 'returning', 'duration', 'scrollDepth'])
        && data.event is string && data.event.size() >= 1 && data.event.size() <= 40
        && data.source is string && data.source.size() <= 80
        && data.referrer is string && data.referrer.size() <= 200
        && data.path is string && data.path.size() <= 100
        && data.device is string && data.device.size() <= 20
        && data.browser is string && data.browser.size() <= 30
        && data.language is string && data.language.size() <= 20
        && data.timezone is string && data.timezone.size() <= 60
        && data.timestamp is number
        && data.meta is string && data.meta.size() <= 120
        // Optional since 2026-07: cached pre-visitor-id bundles still write valid docs.
        && (!('visitorId' in data) || (data.visitorId is string && data.visitorId.size() <= 40))
        && (!('returning' in data) || data.returning is bool)
        // session_end extras: seconds on site and max scroll percentage.
        && (!('duration' in data) || (data.duration is number && data.duration >= 0 && data.duration <= 86400))
        && (!('scrollDepth' in data) || (data.scrollDepth is number && data.scrollDepth >= 0 && data.scrollDepth <= 100));
    }

    // Shape check for public message creation — mirrors the contact form's
    // fields and caps sizes so bots can't dump arbitrary payloads.
    function isValidMessage() {
      let data = request.resource.data;
      return data.keys().hasOnly(['name', 'email', 'subject', 'message', 'timestamp', 'read'])
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100 && data.email.matches('.+@.+\\..+')
        && data.subject is string && data.subject.size() >= 1 && data.subject.size() <= 300
        && data.message is string && data.message.size() >= 1 && data.message.size() <= 2000
        && data.timestamp is number
        && data.read == false;
    }
  }
}
